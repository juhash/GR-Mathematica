-> True\\n];\\n\\nriemannTensor = PacletSymbol[\\\"BowenPing/STensor\\\", \
\\\"BowenPing`STensor`RiemannTensor\\\"][metric];\\nricciTensor = \
PacletSymbol[\\\"BowenPing/STensor\\\", \
