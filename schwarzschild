coordinateNames[[mu]]] +\\n       D[metricMatrix[[mu, sigma]], \
coordinateNames[[nu]]] -\\n       D[metricMatrix[[mu, nu]], \
coordinateNames[[sigma]]]),\\n    {sigma, 1, coordinateCount}\\n  \
]\\n];\\n\\nPrint[\\\"\\\\nChristoffel Symbols (non-zero \
components):\\\"];\\nDo[\\n  Module[{value = christoffel[i, j, k]},\\n    \
If[!TrueQ[Simplify[value == 0]],\\n      Print[Subscript[Superscript[\\\"\
\[CapitalGamma]\\\", i], Row[{j, k}]], \\\" = \\\", value]\\n    ]\\n  ],\\n  \
{i, 1, coordinateCount}, {j, 1, coordinateCount}, {k, 1, \
coordinateCount}\\n];\\n```\\n\\n---\\n\\n## 4. Riemann \
tensor\\n\\n```wl\\n(* Riemann tensor: R^\[Rho]_{\[Sigma]\[Mu]\[Nu]} \
*)\\nriemann[rho_, sigma_, mu_, nu_] := Simplify[\\n  D[christoffel[rho, nu, \
sigma], coordinateNames[[mu]]] -\\n  D[christoffel[rho, mu, sigma], \
coordinateNames[[nu]]] +\\n  Sum[christoffel[rho, mu, \
lambda]*christoffel[lambda, nu, sigma], {lambda, 1, coordinateCount}] -\\n  \
Sum[christoffel[rho, nu, lambda]*christoffel[lambda, mu, sigma], {lambda, 1, \
coordinateCount}]\\n];\\n\\nPrint[\\\"\\\\nRiemann Tensor Components \
(selected non-zero components):\\\"];\\nDo[\\n  Module[{value = riemann[i, j, \
k, l]},\\n    If[!TrueQ[Simplify[value == 0]],\\n      \
Print[Subsuperscript[\\\"R\\\", Row[{j, k, l}], i], \\\" = \\\", value]\\n    \
]\\n  ],\\n  {i, 1, coordinateCount}, {j, 1, coordinateCount}, {k, 1, \
coordinateCount}, {l, 1, coordinateCount}\\n];\\n```\\n\\n---\\n\\n## 5. \
Ricci tensor, Ricci scalar, and Einstein tensor\\n\\n```wl\\n(* Ricci tensor: \
R_{\[Mu]\[Nu]} = R^\[Lambda]_{\[Mu]\[Lambda]\[Nu]} *)\\nricciMatrix = \
Table[\\n  Simplify[Sum[riemann[lambda, mu, lambda, nu], {lambda, 1, \
coordinateCount}]],\\n  {mu, 1, coordinateCount}, {nu, 1, \
coordinateCount}\\n];\\nprintMatrix[\\\"\\\\nRicci Tensor:\\\", ricciMatrix];\
\\n\\nricciScalar = Simplify[\\n  Sum[inverseMetricMatrix[[i, \
j]]*ricciMatrix[[i, j]], {i, 1, coordinateCount}, {j, 1, \
coordinateCount}]\\n];\\nPrint[\\\"\\\\nRicci \
Scalar:\\\"];\\nPrint[ricciScalar];\\n\\neinsteinMatrix = \
Simplify[ricciMatrix - 1/2 \
metricMatrix*ricciScalar];\\nprintMatrix[\\\"\\\\nEinstein Tensor:\\\", \
einsteinMatrix];\\n```\\n\\n---\\n\\n## 6. Using ``BowenPing/STensor`` for a \
